# Environment Configuration
NODE_ENV=development

# Webflow Configuration
WEBFLOW_SITE_ID=your_webflow_site_id_here
WEBFLOW_API_TOKEN=your_webflow_api_token_here
WEBFLOW_CUSTOM_DOMAIN=your-domain.com

# Xano Configuration  
XANO_WORKSPACE_ID=your_xano_workspace_id_here
XANO_API_KEY=your_xano_api_key_here

# Xano Environment URLs
XANO_DEV_URL=https://your-workspace.xano.io/api:your-dev-branch
XANO_STAGING_URL=https://your-workspace.xano.io/api:your-staging-branch
XANO_PROD_URL=https://your-workspace.xano.io/api:your-prod-branch

# Development Configuration
DEV_PORT=3000
HOT_RELOAD=true
WATCH_FILES=true

# Build Configuration
BUILD_OPTIMIZE_ASSETS=true
BUILD_GENERATE_SITEMAP=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:3000